    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\nconst userMap = $('User Mapping').item.json.user_map || {};\nconst config = $('Config').item.json;\n\nfunction toMM(u) { return userMap[u] || u; }\n\nconst sender = toMM(data.sender_username || '');\nconst author = toMM(data.author_username || '');\nconst targets = (data.reviewers?.length > 0 ? data.reviewers : data.assignees) || [];\nconst targetStr = targets.length > 0\n  ? targets.map(r => `@${toMM(r.username)}`).join(' ')\n  : '(리뷰어 미지정)';\n\nconst c1 = config.cmd_review_done || '/리뷰완료';\nconst c2 = config.cmd_review_again || '/리뷰다시';\nconst deadline = config.review_deadline || '24시간 이내';\nconst note = (data.note || '').trim();\n\nlet message = '';\n\nif (data.event_type === 'mr_open') {\n  message = [\n    '----',\n    `##### :gitlab: @${sender}님이 새로운 MR을 등록했습니다!`,\n    '',\n    `- **대상 MR:** [${data.mr_title}](${data.mr_url})\\n`,\n    `- **대표 리뷰어:** ${targetStr}\\n`,\n    '----\\n',\n    `:gunpang_timer: **${deadline}** 확인을 부탁드립니다.\\n`,\n    ':gunpang_paper_log: **MR 페이지 댓글 명령어 안내**',\n    `- **\\`${c1}\\`** : (리뷰어용) 리뷰 완료 후, MR 작성자에게 확인을 요청합니다.`,\n    `- **\\`${c2}\\`** : (작성자용) 리뷰 반영 완료 후, 리뷰어에게 추가 질문/재검토를 요청합니다.\\n`,\n    '----'\n  ].join('\\n');\n} else if (note.startsWith(c1)) {\n  message = [\n    '----',\n    `##### :gitlab: @${sender}님이 리뷰를 완료했습니다! :comp:`,\n    `- **대상 MR:** [${data.mr_title}](${data.mr_url})\\n`,\n    `- **요청 대상:** @${author}\\n`,\n    '----\\n',\n    `:gunpang_timer: **${deadline}** 확인을 부탁드립니다.\\n`,\n    '----'\n  ].join('\\n');\n} else if (note.startsWith(c2)) {\n  const afterCmd = note.slice(c2.length).trim();\n  const mentionMatch = afterCmd.match(/^@(\\S+)/);\n  const finalTargetStr = mentionMatch ? `@${toMM(mentionMatch[1])}` : targetStr;\n  message = [\n    '----',\n    `##### :gitlab: @${sender}님이 추가 확인을 요청했습니다! :please_call:`,\n    '',\n    `- **대상 MR:** [${data.mr_title}](${data.mr_url})\\n`,\n    `- **요청 대상:** ${finalTargetStr}\\n`,\n    '----\\n',\n    `:gunpang_timer: **${deadline}** 확인을 부탁드립니다.\\n`,\n    '----'\n  ].join('\\n');\n} else {\n  return [];\n}\n\nreturn [{ json: { message } }];"
      },
